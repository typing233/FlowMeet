generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String
  avatar        String?
  timezone      String    @default("Asia/Shanghai")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  calendarConnections CalendarConnection[]
  eventTypes          EventType[]
  bookingsAsHost      Booking[]   @relation("BookingsAsHost")
  bookingsAsGuest     Booking[]   @relation("BookingsAsGuest")
}

model CalendarConnection {
  id            String    @id @default(cuid())
  userId        String
  provider      String
  accessToken   String
  refreshToken  String?
  tokenExpiry   DateTime?
  calendarId    String    @default("primary")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, provider])
}

model EventType {
  id              String    @id @default(cuid())
  userId          String
  slug            String
  title           String
  description     String?
  duration        Int
  
  locationType    String    @default("online")
  locationValue   String?
  
  minBookingNotice Int     @default(24)
  bufferTime      Int       @default(0)
  maxBookingsPerDay Int    @default(5)
  
  availability    String    @default("{}")
  customFields    String    @default("[]")
  questions       String    @default("[]")
  
  sendReminder    Boolean   @default(true)
  reminderMinutes Int       @default(60)
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  recommendations BookingRecommendation[]
  
  @@unique([userId, slug])
}

model Booking {
  id              String    @id @default(cuid())
  eventTypeId     String
  hostId          String
  guestEmail      String
  guestName       String
  startTime       DateTime
  endTime         DateTime
  timezone        String    @default("Asia/Shanghai")
  
  guestPhone      String?
  guestNotes      String?
  customResponses String    @default("{}")
  
  status          String    @default("confirmed")
  
  meetingUrl      String?
  location        String?
  
  reminderSent    Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  eventType       EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  host            User      @relation("BookingsAsHost", fields: [hostId], references: [id], onDelete: Cascade)
  guest           User?     @relation("BookingsAsGuest", fields: [guestUserId], references: [id])
  
  guestUserId     String?
  
  timelineEvents  BookingTimelineEvent[]
  notifications   NotificationLog[]
}

model AIChatSession {
  id              String    @id @default(cuid())
  userId          String
  title           String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  messages        AIChatMessage[]
  
  @@index([userId])
}

model AIChatMessage {
  id              String    @id @default(cuid())
  sessionId       String
  role            String
  content         String
  
  intent          String?
  intentData      String?
  
  createdAt       DateTime  @default(now())
  
  session         AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

model AIPendingAction {
  id              String    @id @default(cuid())
  userId          String
  sessionId       String
  
  actionType      String
  actionData      String
  previewData     String
  
  status          String    @default("pending")
  
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  
  @@index([userId])
  @@index([sessionId])
}

model BookingRecommendation {
  id              String    @id @default(cuid())
  eventTypeId     String
  guestTimezone   String    @default("Asia/Shanghai")
  
  originalDate    DateTime
  recommendedDate DateTime
  
  timezoneDiff    Int       @default(0)
  commuteMinutes  Int       @default(0)
  hostLoadScore   Float     @default(0.0)
  
  tags            String    @default("[]")
  score           Float     @default(0.0)
  
  createdAt       DateTime  @default(now())
  
  eventType       EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  
  @@index([eventTypeId])
}

model BookingTimelineEvent {
  id              String    @id @default(cuid())
  bookingId       String
  eventType       String
  eventData       String    @default("{}")
  
  triggeredBy     String?
  triggeredAt     DateTime  @default(now())
  
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([bookingId])
}

model NotificationRule {
  id              String    @id @default(cuid())
  userId          String
  
  name            String
  triggerType     String
  triggerOffset   Int       @default(0)
  
  channelType     String
  channelConfig   String    @default("{}")
  
  template        String?
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

model NotificationLog {
  id              String    @id @default(cuid())
  bookingId       String
  ruleId          String?
  
  channelType     String
  recipient       String
  subject         String?
  content         String?
  
  status          String    @default("sent")
  errorMessage    String?
  
  sentAt          DateTime  @default(now())
  
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([bookingId])
}

model WebhookSubscription {
  id              String    @id @default(cuid())
  userId          String
  
  name            String
  url             String
  secret          String?
  
  events          String    @default("[]")
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

model WebhookLog {
  id              String    @id @default(cuid())
  subscriptionId  String
  eventType       String
  payload         String
  
  statusCode      Int?
  response        String?
  errorMessage    String?
  
  sentAt          DateTime  @default(now())
  
  @@index([subscriptionId])
}
